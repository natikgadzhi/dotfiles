
# Keybinds
#
keybind = ctrl+z=close_surface
keybind = shift+ctrl+d=new_split:right
keybind = shift+ctrl+v=new_split:down
keybind = global:ctrl+`=toggle_quick_terminal
keybind = shift+ctrl+.=reload_config
keybind = cmd+shift+w=close_window

keybind = shift+enter=text:\n

# Visual font, theme, cursors
#
font-family = "Doom One"
font-size = 16

# Try `xcodedarkhc` for higher contrast
theme = "Horizon"
cursor-style = block

initial-window = false


# Shell and OS integration
#
term=xterm-256color

# Fish is set as system shell so the config is portable
# command = /opt/homebrew/bin/fish --login --interactive
shell-integration = fish
shell-integration-features = cursor, sudo, title, ssh-env, ssh-terminfo

# Decoration was broken on MacOS 26
macos-titlebar-style = tabs
# window-decoration = false
window-theme = system
macos-option-as-alt = true

# YOLO updates
auto-update-channel = tip


# Don't show a dialog when I'm slamming cmd+q
#
confirm-close-surface = false

# Auto-update settings
#
auto-update = download


# Quick Terminal
#
quick-terminal-animation-duration = 0
quick-terminal-position = center
quick-terminal-autohide = true
quick-terminal-size = 50%
quick-terminal-screen = main
